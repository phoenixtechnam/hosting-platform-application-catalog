{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/phoenixtechnam/hosting-platform-application-catalog/schema/app-manifest.schema.json",
  "title": "Application Manifest",
  "description": "Schema for application catalog manifest.json files used by the K8s Hosting Platform. Applications are self-contained, Helm-deployed stacks.",
  "type": "object",
  "required": [
    "name",
    "code",
    "version",
    "description",
    "category",
    "min_plan",
    "tenancy",
    "components",
    "networking",
    "volumes",
    "resources",
    "health_check",
    "parameters",
    "tags"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable display name",
      "minLength": 1,
      "maxLength": 255
    },
    "code": {
      "type": "string",
      "description": "Unique identifier slug (must match directory name)",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 2,
      "maxLength": 50
    },
    "version": {
      "type": "string",
      "description": "Application version or version pattern (e.g., '28', '6.x', 'stable')",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Short description shown in catalog UI",
      "minLength": 1,
      "maxLength": 500
    },
    "category": {
      "type": "string",
      "description": "Application category for grouping in the UI",
      "enum": [
        "cms",
        "productivity",
        "communication",
        "education",
        "development",
        "analytics",
        "identity",
        "ecommerce",
        "media",
        "other"
      ]
    },
    "min_plan": {
      "type": "string",
      "description": "Minimum hosting plan required",
      "enum": ["starter", "business", "premium"]
    },
    "tenancy": {
      "type": "array",
      "description": "Supported tenancy modes",
      "items": {
        "type": "string",
        "enum": ["single-tenant", "multi-tenant"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "components": {
      "type": "array",
      "description": "Kubernetes resources this application deploys",
      "items": {
        "type": "object",
        "required": ["name", "type", "image"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Component name (used in template naming)",
            "pattern": "^[a-z0-9-]+$"
          },
          "type": {
            "type": "string",
            "description": "Kubernetes resource type",
            "enum": ["deployment", "statefulset", "cronjob", "job"]
          },
          "image": {
            "type": "string",
            "description": "Container image reference",
            "minLength": 1
          },
          "ports": {
            "type": "array",
            "description": "Ports this component exposes",
            "items": {
              "type": "object",
              "required": ["port", "protocol"],
              "properties": {
                "port": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                },
                "protocol": {
                  "type": "string",
                  "enum": ["TCP", "UDP"]
                },
                "ingress": {
                  "type": "boolean",
                  "description": "Whether this port is exposed via the NGINX Ingress Controller",
                  "default": false
                }
              },
              "additionalProperties": false
            }
          },
          "optional": {
            "type": "boolean",
            "description": "Whether this component can be disabled via parameters",
            "default": false
          },
          "schedule": {
            "type": "string",
            "description": "Cron schedule (only for cronjob type)",
            "pattern": "^[0-9*/,-]+\\s+[0-9*/,-]+\\s+[0-9*/,-]+\\s+[0-9*/,-]+\\s+[0-9*/,-]+$"
          }
        },
        "additionalProperties": false,
        "if": {
          "properties": { "type": { "const": "cronjob" } }
        },
        "then": {
          "required": ["schedule"]
        }
      },
      "minItems": 1
    },
    "networking": {
      "type": "object",
      "description": "Network exposure requirements",
      "required": ["ingress_ports"],
      "properties": {
        "ingress_ports": {
          "type": "array",
          "description": "Ports exposed via NGINX Ingress with TLS",
          "items": {
            "type": "object",
            "required": ["port", "protocol", "tls"],
            "properties": {
              "port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "protocol": {
                "type": "string",
                "enum": ["TCP"]
              },
              "tls": {
                "type": "boolean"
              },
              "description": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "host_ports": {
          "type": "array",
          "description": "Ports that require direct host-level exposure (UDP media, SSH, etc.)",
          "items": {
            "type": "object",
            "required": ["port", "protocol", "component", "description"],
            "properties": {
              "port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "protocol": {
                "type": "string",
                "enum": ["TCP", "UDP"]
              },
              "component": {
                "type": "string",
                "description": "Which component needs this port"
              },
              "description": {
                "type": "string"
              },
              "optional": {
                "type": "boolean",
                "default": false
              },
              "remappable": {
                "type": "boolean",
                "description": "Whether the platform can assign a different port",
                "default": false
              },
              "remap_range": {
                "type": "array",
                "description": "Port range for remapping [min, max]",
                "items": { "type": "integer" },
                "minItems": 2,
                "maxItems": 2
              },
              "max_instances_per_node": {
                "type": "integer",
                "description": "Max concurrent instances on one node (for non-remappable ports)",
                "minimum": 1
              }
            },
            "additionalProperties": false
          }
        },
        "websocket": {
          "type": "boolean",
          "description": "Whether the app requires WebSocket upgrade support",
          "default": false
        },
        "notes": {
          "type": "string",
          "description": "Additional networking notes for operators"
        }
      },
      "additionalProperties": false
    },
    "volumes": {
      "type": "array",
      "description": "Persistent volumes this application needs",
      "items": {
        "type": "object",
        "required": ["name", "mount_path", "default_size"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "mount_path": {
            "type": "string",
            "pattern": "^/"
          },
          "default_size": {
            "type": "string",
            "description": "Default PVC size (e.g., '5Gi', '100Mi')",
            "pattern": "^[0-9]+(Mi|Gi)$"
          },
          "description": {
            "type": "string"
          },
          "optional": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      }
    },
    "resources": {
      "type": "object",
      "description": "Resource allocation profiles",
      "required": ["default", "minimum"],
      "properties": {
        "default": {
          "type": "object",
          "required": ["cpu", "memory", "storage"],
          "properties": {
            "cpu": { "type": "string", "pattern": "^[0-9]+\\.?[0-9]*$" },
            "memory": { "type": "string", "pattern": "^[0-9]+(Mi|Gi)$" },
            "storage": { "type": "string", "pattern": "^[0-9]+(Mi|Gi)$" }
          },
          "additionalProperties": false
        },
        "minimum": {
          "type": "object",
          "required": ["cpu", "memory", "storage"],
          "properties": {
            "cpu": { "type": "string", "pattern": "^[0-9]+\\.?[0-9]*$" },
            "memory": { "type": "string", "pattern": "^[0-9]+(Mi|Gi)$" },
            "storage": { "type": "string", "pattern": "^[0-9]+(Mi|Gi)$" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "health_check": {
      "type": "object",
      "description": "Primary health check for the main web component",
      "required": ["path", "port", "initial_delay_seconds", "period_seconds"],
      "properties": {
        "path": {
          "type": "string",
          "description": "HTTP GET path"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "initial_delay_seconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 600
        },
        "period_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        }
      },
      "additionalProperties": false
    },
    "parameters": {
      "type": "array",
      "description": "Admin-configurable parameters shown in the deployment UI, passed as Helm values",
      "items": {
        "type": "object",
        "required": ["key", "label", "type"],
        "properties": {
          "key": {
            "type": "string",
            "description": "Helm values path (e.g., 'admin.username', 'smtp.host')",
            "pattern": "^[a-zA-Z0-9_.]+$"
          },
          "label": {
            "type": "string",
            "description": "Human-readable label for the UI"
          },
          "type": {
            "type": "string",
            "description": "Parameter type",
            "enum": ["string", "secret", "boolean", "integer", "string[]"]
          },
          "default": {
            "description": "Default value (type matches parameter type)"
          },
          "required": {
            "type": "boolean",
            "default": false
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "tags": {
      "type": "array",
      "description": "Keywords for filtering and search",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
